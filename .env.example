# 复制此文件为 .env 并填写实际配置

# 卓沅社交媒体账号ID (需要根据实际页面获取)
ZHUOYUAN_WEBO_UID=1234567890
ZHUOYUAN_XHS_UID=zhuoyuan
ZHUOYUAN_DOUYIN_UID=zhuoyuan

# 邮件配置 (以 Gmail 为例)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# 爬虫配置
HEADLESS=true
TIMEOUT=30

# 定时任务配置 (每天早上9点)
SCHEDULE_TIME=09:00
